# 100 Days of AI Agents - API Keys
# Copy this to .env and fill in your keys

# OpenAI (Days 4, 22-28, and throughout)
OPENAI_API_KEY=sk-...

# Anthropic / Claude (Days 43-44, and throughout)
ANTHROPIC_API_KEY=sk-ant-...

# Google / Gemini (Day 45)
GOOGLE_API_KEY=...

# Pinecone (Day 11)
PINECONE_API_KEY=...

# Cohere (Day 12)
COHERE_API_KEY=...

# LangSmith (Days 34, 61, 90)
LANGCHAIN_API_KEY=...
LANGCHAIN_TRACING_V2=true

# AWS (Days 83, 90)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1
